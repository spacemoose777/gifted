rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Returns true if the requester and ownerUid share the same non-null familyId.
    // Both user documents must be readable (see /users/{userId} rule below).
    function shareFamily(ownerUid) {
      let me = get(/databases/$(database)/documents/users/$(request.auth.uid));
      let owner = get(/databases/$(database)/documents/users/$(ownerUid));
      let myFamily = me.data.get('familyId', '');
      let ownerFamily = owner.data.get('familyId', '');
      return isAuth() && myFamily != '' && myFamily == ownerFamily;
    }

    // ── User document (top-level, not subcollection) ──────────────────────────
    // Readable by any authenticated user so shareFamily() can look up familyId.
    // Writable by owner only.
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isOwner(userId);
    }

    // ── People ────────────────────────────────────────────────────────────────
    // Owner: full access. Family member: read only (client filters isPrivate).
    match /users/{userId}/people/{personId} {
      allow read, write: if isOwner(userId);
      allow read: if shareFamily(userId);
    }

    // ── Gifts (subcollection of people) ──────────────────────────────────────
    // Always private — family members cannot read gift ideas.
    match /users/{userId}/people/{personId}/gifts/{giftId} {
      allow read, write: if isOwner(userId);
    }

    // ── Wishlist ──────────────────────────────────────────────────────────────
    match /users/{userId}/wishlist/{itemId} {
      allow read, write: if isOwner(userId);
    }

    // ── Events ────────────────────────────────────────────────────────────────
    // Owner: full access. Family member: read only (client filters isPrivate).
    match /users/{userId}/events/{eventId} {
      allow read, write: if isOwner(userId);
      allow read: if shareFamily(userId);
    }

    // ── Encryption config ─────────────────────────────────────────────────────
    match /users/{userId}/config/{docId} {
      allow read, write: if isOwner(userId);
    }

    // ── Families ──────────────────────────────────────────────────────────────
    // Members can read their family. Anyone can create (must include self).
    // Members can update (e.g. to add a new member via arrayUnion).
    match /families/{familyId} {
      allow read: if isAuth() && request.auth.uid in resource.data.memberUids;
      allow create: if isAuth() && request.auth.uid in request.resource.data.memberUids;
      allow update: if isAuth() && request.auth.uid in request.resource.data.memberUids;
    }

    // ── Invite codes ──────────────────────────────────────────────────────────
    // Any authenticated user can read (to look up a code and join).
    // Only authenticated users can create/write.
    match /inviteCodes/{code} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
  }
}
